{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.makemind.com/mcp_ui_dsl/1.3/theme.schema.json",
  "title": "MCP UI DSL 1.3 — Theme",
  "type": "object",
  "properties": {
    "mode": {
      "enum": [
        "light",
        "dark",
        "system"
      ],
      "default": "system"
    },
    "color": {
      "$ref": "#/$defs/Color"
    },
    "typography": {
      "$ref": "#/$defs/Typography"
    },
    "spacing": {
      "$ref": "#/$defs/Spacing"
    },
    "shape": {
      "$ref": "#/$defs/Shape"
    },
    "elevation": {
      "$ref": "#/$defs/Elevation"
    },
    "motion": {
      "$ref": "#/$defs/Motion"
    },
    "density": {
      "$ref": "#/$defs/Density"
    },
    "breakpoints": {
      "$ref": "#/$defs/Breakpoints"
    },
    "border": {
      "$ref": "#/$defs/Border"
    },
    "opacity": {
      "$ref": "#/$defs/Opacity"
    },
    "focusRing": {
      "$ref": "#/$defs/FocusRing"
    },
    "zIndex": {
      "$ref": "#/$defs/ZIndex"
    },
    "component": {
      "$ref": "#/$defs/Component"
    },
    "preset": {
      "$ref": "#/$defs/ThemePreset",
      "description": "Curated theme bundle applied as the base. Other top-level fields layer overrides on top."
    },
    "fonts": {
      "$ref": "#/$defs/FontRegistry",
      "description": "Font asset registration (variable-axis tunings + per-weight files + fallbacks)."
    },
    "light": {
      "$ref": "#"
    },
    "dark": {
      "$ref": "#"
    }
  },
  "additionalProperties": false,
  "description": "Theme tokens per docs/05_Theme.md. M3 naming + DTCG-friendly + shadcn-style semantic. No legacy aliases.",
  "$defs": {
    "Alignment": {
      "oneOf": [
        {
          "enum": [
            "topStart",
            "topCenter",
            "topEnd",
            "centerStart",
            "center",
            "centerEnd",
            "bottomStart",
            "bottomCenter",
            "bottomEnd"
          ]
        },
        {
          "type": "object",
          "properties": {
            "x": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            },
            "y": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            }
          },
          "required": [
            "x",
            "y"
          ],
          "additionalProperties": false
        },
        {
          "$ref": "#/$defs/Binding"
        }
      ],
      "description": "2D alignment within a rectangle. Token names are **directional**\n(RTL-aware) per Material 3:\n\n- `topStart` — top corner on the leading edge (top-left in LTR,\n  top-right in RTL).\n- `topEnd` — top corner on the trailing edge.\n- `centerStart` / `centerEnd`, `bottomStart` / `bottomEnd` — same\n  convention on the middle / bottom rows.\n- `topCenter`, `center`, `bottomCenter` — neutral on the cross\n  axis.\n\nObject form `{x, y}` is a numeric pair where each axis runs from\n-1 (start) through 0 (center) to 1 (end). The numeric form\nsupports any point inside or outside the rectangle.\n\nCross-schema canonical for any \"2D rectangle alignment\" use —\nchild placement (`box.alignment`, `align.alignment`,\n`stack.alignment`), gradient endpoints (`Gradient.begin/end`),\nimage fit (`BackgroundImage.alignment`)."
    },
    "AnimationCurve": {
      "enum": [
        "linear",
        "easeIn",
        "easeOut",
        "easeInOut",
        "standard",
        "standardAccelerate",
        "standardDecelerate",
        "emphasized",
        "emphasizedAccelerate",
        "emphasizedDecelerate",
        "bounceIn",
        "bounceOut"
      ],
      "description": "Easing curve applied to an animation's progress. Eleven canonical\nvalues cover the M3-recommended palette plus the CSS-familiar\nbasics:\n\n- **CSS-familiar** — `linear`, `easeIn`, `easeOut`, `easeInOut`.\n- **M3 standard** — `standard`, `standardAccelerate`,\n  `standardDecelerate`. Used for everyday transitions; minimal\n  overshoot, clean cubic.\n- **M3 emphasized** — `emphasized`, `emphasizedAccelerate`,\n  `emphasizedDecelerate`. Used for hero / page transitions; more\n  dramatic acceleration profile.\n- **Bounce** — `bounceIn`, `bounceOut`. For attention / alert\n  micro-interactions.\n\nCross-schema canonical for `animatedContainer.curve`,\n`animatedOpacity.curve`, RouteTransition, scrollAnimated easing,\nand any future implicit-animation widget. Matches the M3 motion\nspec's named tokens 1:1 so theme-level motion overrides stay\nvendor-neutral."
    },
    "AssetRef": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(bundle://|https?://|data:|assets/|client://)"
        },
        {
          "$ref": "#/$defs/Binding"
        }
      ],
      "description": "Reference to an asset (image, font, audio, video, SVG, …). Five\nscheme prefixes are accepted, picked by the runtime to dispatch\nthe right loader:\n\n- `bundle://<path>` — asset packaged inside the active bundle.\n- `https://<url>` / `http://<url>` — fetched over the network and\n  cached on first render.\n- `data:<mime>;base64,<payload>` (or `data:<mime>,<urlencoded>`) —\n  inline bytes carried in the DSL itself.\n- `assets/<path>` — Flutter-style local asset path declared in the\n  consumer app's pubspec asset list (used by host integrations that\n  ship icon SVGs alongside the runtime).\n- `client://<channel>/<id>` — resource served by the client / host\n  process via an MCP client-extension channel.\n\nUsed cross-schema by `app` (splash · publisher logos · font\nassets), `page`/widgets (image · icon · BackgroundImage · video\nsrc), and `theme` (font asset registration). Lives under\n`configs/_primitive/` for that reason."
    },
    "BackgroundImage": {
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/$defs/AssetRef"
        },
        "fit": {
          "enum": [
            "fill",
            "contain",
            "cover",
            "fitWidth",
            "fitHeight",
            "none",
            "scaleDown"
          ],
          "default": "cover"
        },
        "alignment": {
          "$ref": "#/$defs/Alignment"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "colorFilter": {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "blendMode": {
              "enum": [
                "srcIn",
                "color",
                "screen",
                "overlay",
                "multiply"
              ],
              "default": "srcIn",
              "description": "Curated subset of blend modes covering the common tinting use cases (`srcIn` for solid tint, `color` for hue swap, `screen`/`overlay`/`multiply` for atmosphere)."
            }
          },
          "required": [
            "color"
          ],
          "additionalProperties": false
        },
        "repeat": {
          "enum": [
            "noRepeat",
            "repeat",
            "repeatX",
            "repeatY"
          ],
          "default": "noRepeat"
        }
      },
      "required": [
        "image"
      ],
      "additionalProperties": false,
      "description": "Image fill behind a box's content. `image` accepts the same forms as\nthe `image` widget's `src` (`bundle://`, `https?://`, `data:`,\n`client://`). `fit` and `alignment` mirror the `image` widget's\nsemantics. `opacity` applies an alpha multiplier; `colorFilter`\ncomposites a tint via the named blend mode. `repeat` controls\ntiling behaviour outside the image's natural bounds."
    },
    "Binding": {
      "type": "string",
      "pattern": "^\\{\\{.*\\}\\}$",
      "description": "Binding-expression string of the form `\"{{...}}\"`. Authors may\nsubstitute any primitive value with a binding so the runtime\nresolves the value at render time. Used as an alternative branch\nin primitives that otherwise expect a specific structural shape\n(AssetRef, Dimension, BorderRadius, Alignment, …)."
    },
    "Border": {
      "type": "object",
      "properties": {
        "width": {
          "type": "object",
          "properties": {
            "hairline": {
              "type": "number"
            },
            "thin": {
              "type": "number"
            },
            "normal": {
              "type": "number"
            },
            "thick": {
              "type": "number"
            },
            "heavy": {
              "type": "number"
            }
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "style": {
          "enum": [
            "solid",
            "dashed",
            "dotted"
          ]
        }
      },
      "additionalProperties": false
    },
    "BorderRadius": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "object",
          "properties": {
            "topStart": {
              "type": "number",
              "minimum": 0
            },
            "topEnd": {
              "type": "number",
              "minimum": 0
            },
            "bottomStart": {
              "type": "number",
              "minimum": 0
            },
            "bottomEnd": {
              "type": "number",
              "minimum": 0
            },
            "all": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        {
          "$ref": "#/$defs/Binding"
        }
      ],
      "description": "Per-corner radius value. A bare number applies uniformly to all\nfour corners; the object form lets each corner take an independent\nradius. `all` is a shorthand for setting every corner at once and\nis overridden by individual corner keys.\n\nCorner names are **directional** (RTL-aware) per Material 3:\n\n- `topStart` — top corner on the leading edge (top-left in LTR,\n  top-right in RTL).\n- `topEnd` — top corner on the trailing edge.\n- `bottomStart` / `bottomEnd` — same convention on the bottom row.\n\nThis is the cross-schema canonical for any \"per-corner radius\"\nshape — referenced by `theme.Shape` (M3 shape token sizes) and by\nthe `BoxDecoration.borderRadius` widget property."
    },
    "Breakpoints": {
      "type": "object",
      "properties": {
        "compact": {
          "type": "number"
        },
        "medium": {
          "type": "number"
        },
        "expanded": {
          "type": "number"
        },
        "large": {
          "type": "number"
        },
        "extraLarge": {
          "type": "number"
        }
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "Color": {
      "type": "object",
      "properties": {
        "seed": {
          "$ref": "#/$defs/ColorValue"
        },
        "primary": {
          "$ref": "#/$defs/ColorValue"
        },
        "onPrimary": {
          "$ref": "#/$defs/ColorValue"
        },
        "primaryContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "onPrimaryContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "secondary": {
          "$ref": "#/$defs/ColorValue"
        },
        "onSecondary": {
          "$ref": "#/$defs/ColorValue"
        },
        "secondaryContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "onSecondaryContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "tertiary": {
          "$ref": "#/$defs/ColorValue"
        },
        "onTertiary": {
          "$ref": "#/$defs/ColorValue"
        },
        "tertiaryContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "onTertiaryContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "error": {
          "$ref": "#/$defs/ColorValue"
        },
        "onError": {
          "$ref": "#/$defs/ColorValue"
        },
        "errorContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "onErrorContainer": {
          "$ref": "#/$defs/ColorValue"
        },
        "surface": {
          "$ref": "#/$defs/ColorValue"
        },
        "onSurface": {
          "$ref": "#/$defs/ColorValue"
        },
        "surfaceVariant": {
          "$ref": "#/$defs/ColorValue"
        },
        "onSurfaceVariant": {
          "$ref": "#/$defs/ColorValue"
        },
        "surfaceTint": {
          "$ref": "#/$defs/ColorValue"
        },
        "background": {
          "$ref": "#/$defs/ColorValue"
        },
        "onBackground": {
          "$ref": "#/$defs/ColorValue"
        },
        "outline": {
          "$ref": "#/$defs/ColorValue"
        },
        "outlineVariant": {
          "$ref": "#/$defs/ColorValue"
        },
        "inverseSurface": {
          "$ref": "#/$defs/ColorValue"
        },
        "inverseOnSurface": {
          "$ref": "#/$defs/ColorValue"
        },
        "inversePrimary": {
          "$ref": "#/$defs/ColorValue"
        },
        "scrim": {
          "$ref": "#/$defs/ColorValue"
        },
        "shadow": {
          "$ref": "#/$defs/ColorValue"
        },
        "success": {
          "$ref": "#/$defs/ColorValue"
        },
        "onSuccess": {
          "$ref": "#/$defs/ColorValue"
        },
        "warning": {
          "$ref": "#/$defs/ColorValue"
        },
        "onWarning": {
          "$ref": "#/$defs/ColorValue"
        },
        "info": {
          "$ref": "#/$defs/ColorValue"
        },
        "onInfo": {
          "$ref": "#/$defs/ColorValue"
        },
        "stateLayer": {
          "type": "object",
          "properties": {
            "hover": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "focus": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "pressed": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "disabled": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ColorValue": {
      "type": "string",
      "pattern": "^(#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})|rgba?\\([^)]+\\)|\\{\\{[^}]+\\}\\})$"
    },
    "Component": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "Density": {
      "type": "object",
      "properties": {
        "comfortable": {
          "$ref": "#/$defs/DensityValue"
        },
        "standard": {
          "$ref": "#/$defs/DensityValue"
        },
        "compact": {
          "$ref": "#/$defs/DensityValue"
        },
        "active": {
          "enum": [
            "comfortable",
            "standard",
            "compact"
          ]
        }
      },
      "additionalProperties": false
    },
    "DensityValue": {
      "type": "object",
      "properties": {
        "vertical": {
          "type": "number",
          "minimum": -4,
          "maximum": 4
        },
        "horizontal": {
          "type": "number",
          "minimum": -4,
          "maximum": 4
        }
      },
      "required": [
        "vertical",
        "horizontal"
      ],
      "additionalProperties": false
    },
    "Dimension": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        },
        {
          "$ref": "#/$defs/Binding"
        }
      ],
      "description": "Numeric size — accepts a plain `number` (logical pixels) OR the\nlegacy MCP UI DSL v1.0 `{value, unit}` object form. The `unit`\nfield is informational; the runtime treats every dimension as\nlogical pixels."
    },
    "Elevation": {
      "type": "object",
      "properties": {
        "level0": {
          "$ref": "#/$defs/ElevationLevel"
        },
        "level1": {
          "$ref": "#/$defs/ElevationLevel"
        },
        "level2": {
          "$ref": "#/$defs/ElevationLevel"
        },
        "level3": {
          "$ref": "#/$defs/ElevationLevel"
        },
        "level4": {
          "$ref": "#/$defs/ElevationLevel"
        },
        "level5": {
          "$ref": "#/$defs/ElevationLevel"
        }
      },
      "additionalProperties": false
    },
    "ElevationLevel": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "object",
          "properties": {
            "shadow": {
              "type": "number"
            },
            "tint": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "FocusRing": {
      "type": "object",
      "properties": {
        "color": {
          "$ref": "#/$defs/ColorValue"
        },
        "width": {
          "type": "number"
        },
        "offset": {
          "type": "number"
        },
        "radius": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "FontRegistry": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "weights": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/AssetRef"
            }
          },
          "variableAxes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tag": {
                  "type": "string",
                  "minLength": 4,
                  "maxLength": 4
                },
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "default": {
                  "type": "number"
                }
              },
              "required": [
                "tag",
                "min",
                "max"
              ],
              "additionalProperties": false
            }
          },
          "fallbacks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "description": "Font asset registration. Map of font family name → asset\ndeclaration. Each declaration tells the runtime which file to\nload for a given weight/style and, for variable fonts, which\naxes are tunable.\n\n- `weights` — map of weight value (`100`..`900` or `regular`/\n  `bold`/etc.) to AssetRef. Set per file you want to ship.\n- `variableAxes` — list of variable-font axis tunings. Each entry\n  is `{tag, min, max, default}`. Standard axes: `wght` (weight),\n  `wdth` (width), `opsz` (optical size), `ital` (italic), `slnt`\n  (slant). Custom axes (`GRAD`, `XOPQ`, etc.) are accepted by tag.\n  When set, `weights` becomes optional — the runtime drives the\n  `wght` axis from text.style.fontWeight.\n- `fallbacks` — ordered family-name list used when a glyph isn't\n  in the primary font (CJK, emoji, math)."
    },
    "Gradient": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "linear",
            "radial",
            "sweep"
          ]
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "stops": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "begin": {
          "$ref": "#/$defs/Alignment"
        },
        "end": {
          "$ref": "#/$defs/Alignment"
        },
        "center": {
          "$ref": "#/$defs/Alignment"
        },
        "radius": {
          "type": "number",
          "minimum": 0
        },
        "startAngle": {
          "type": "number"
        },
        "endAngle": {
          "type": "number"
        },
        "tileMode": {
          "enum": [
            "clamp",
            "repeated",
            "mirror"
          ],
          "default": "clamp"
        }
      },
      "required": [
        "type",
        "colors"
      ],
      "additionalProperties": false,
      "description": "Multi-stop gradient fill. Selected by `type`:\n\n- `linear` — straight axis from `begin` (default `centerLeft`) to\n  `end` (default `centerRight`).\n- `radial` — circular gradient out from `center` (default `center`)\n  to `radius` (default `0.5`, expressed as a fraction of the\n  bounding rectangle's longest side).\n- `sweep` — angular gradient around `center`, swept from\n  `startAngle` (default `0`) to `endAngle` (default `2π`) in\n  radians.\n\n`colors` lists at least two color values; `stops` (optional) places\neach color at a position in `[0, 1]`. `tileMode` controls behaviour\npast the gradient extents."
    },
    "Motion": {
      "type": "object",
      "properties": {
        "duration": {
          "type": "object",
          "properties": {
            "short1": {
              "type": "number"
            },
            "short2": {
              "type": "number"
            },
            "short3": {
              "type": "number"
            },
            "short4": {
              "type": "number"
            },
            "medium1": {
              "type": "number"
            },
            "medium2": {
              "type": "number"
            },
            "medium3": {
              "type": "number"
            },
            "medium4": {
              "type": "number"
            },
            "long1": {
              "type": "number"
            },
            "long2": {
              "type": "number"
            },
            "long3": {
              "type": "number"
            },
            "long4": {
              "type": "number"
            },
            "extraLong": {
              "type": "number"
            }
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "easing": {
          "type": "object",
          "properties": {
            "standard": {
              "type": "string"
            },
            "emphasized": {
              "type": "string"
            },
            "decelerate": {
              "type": "string"
            },
            "accelerate": {
              "type": "string"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "NavigationStyle": {
      "type": "object",
      "properties": {
        "backgroundColor": {
          "type": "string"
        },
        "backgroundImage": {
          "$ref": "#/$defs/BackgroundImage"
        },
        "indicatorColor": {
          "type": "string",
          "description": "Selection indicator pill color (rail / drawer / tabs)."
        },
        "indicatorShape": {
          "$ref": "#/$defs/BorderRadius",
          "description": "Selection indicator corner radius. Defaults to a fully-rounded pill."
        },
        "dividerColor": {
          "type": "string",
          "description": "Drawer-only — color of dividers between item groups."
        },
        "dividerThickness": {
          "$ref": "#/$defs/Dimension"
        },
        "dividerIndent": {
          "$ref": "#/$defs/Dimension",
          "description": "Drawer-only — leading inset before each divider."
        },
        "labelStyle": {
          "$ref": "#/$defs/TextStyle",
          "description": "Default text style for item labels (selected and unselected). Per-item override via NavItem.style.labelStyle."
        },
        "iconStyle": {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "size": {
              "$ref": "#/$defs/Dimension"
            }
          },
          "additionalProperties": false,
          "description": "Default icon color and size."
        },
        "selectedColor": {
          "type": "string",
          "description": "Foreground color (icon + label) for the selected item."
        },
        "unselectedColor": {
          "type": "string",
          "description": "Foreground color for non-selected items."
        },
        "elevation": {
          "$ref": "#/$defs/Dimension"
        }
      },
      "additionalProperties": false,
      "description": "Visual styling for a navigation surface (drawer / rail / tabs /\nbottomBar). Every field is optional — omitted fields fall back to\nthe active theme's component defaults. Used by\n`NavigationConfig.style` (whole surface) and `NavItem.style`\n(per-item override).\n\nBackgrounds compose: `backgroundColor` paints first, then\n`backgroundImage` paints over it."
    },
    "Opacity": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "RouteTransition": {
      "type": "object",
      "properties": {
        "style": {
          "enum": [
            "slide",
            "fade",
            "scale",
            "cube",
            "sharedAxis",
            "fadeThrough"
          ]
        },
        "duration": {
          "$ref": "#/$defs/Dimension",
          "description": "Total transition duration in milliseconds. Defaults to the M3 motion-system value for the chosen style."
        },
        "curve": {
          "$ref": "#/$defs/AnimationCurve",
          "description": "Easing curve for the transition's progress. Defaults to `emphasized`."
        },
        "axis": {
          "enum": [
            "horizontal",
            "vertical"
          ],
          "description": "Direction for `slide` / `sharedAxis`. Defaults to `horizontal`."
        },
        "reverse": {
          "type": "boolean",
          "default": false,
          "description": "When true, run the transition in reverse direction (for back navigation)."
        }
      },
      "required": [
        "style"
      ],
      "additionalProperties": false,
      "description": "Per-route page transition. Declared on a `RouteValue` so every\n`navigate` to that route uses the same transition, OR overridden\ninline on a `navigate` action. Six canonical styles:\n\n- `slide` — incoming page slides over the outgoing along the\n  direction (M3 default for forward navigation).\n- `fade` — cross-fade between pages at the same position.\n- `scale` — outgoing scales out, incoming scales in.\n- `cube` — perspective-rotate as if turning a 3D cube; needs a\n  perspective-aware compositor (falls back to `slide` when\n  unavailable).\n- `sharedAxis` — coordinated slide+fade across an axis (M3 motion\n  pattern for sibling-level navigation).\n- `fadeThrough` — outgoing fades out while incoming fades in\n  after a brief zero-opacity bridge (M3 motion pattern for\n  top-level navigation)."
    },
    "Shape": {
      "type": "object",
      "properties": {
        "none": {
          "$ref": "#/$defs/BorderRadius"
        },
        "extraSmall": {
          "$ref": "#/$defs/BorderRadius"
        },
        "small": {
          "$ref": "#/$defs/BorderRadius"
        },
        "medium": {
          "$ref": "#/$defs/BorderRadius"
        },
        "large": {
          "$ref": "#/$defs/BorderRadius"
        },
        "extraLarge": {
          "$ref": "#/$defs/BorderRadius"
        },
        "full": {
          "$ref": "#/$defs/BorderRadius"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/BorderRadius"
      }
    },
    "Spacing": {
      "type": "object",
      "properties": {
        "xxs": {
          "type": "number"
        },
        "xs": {
          "type": "number"
        },
        "sm": {
          "type": "number"
        },
        "md": {
          "type": "number"
        },
        "lg": {
          "type": "number"
        },
        "xl": {
          "type": "number"
        },
        "2xl": {
          "type": "number"
        },
        "3xl": {
          "type": "number"
        },
        "4xl": {
          "type": "number"
        },
        "screenPadding": {
          "type": "number"
        },
        "cardPadding": {
          "type": "number"
        },
        "sectionGap": {
          "type": "number"
        },
        "inlineGap": {
          "type": "number"
        }
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "TextStyle": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\{\\{.*\\}\\}$",
          "description": "Binding expression that resolves to a TextStyle object — typically `{{theme.typography.<role>}}`."
        },
        {
          "type": "object",
          "properties": {
            "fontFamily": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            },
            "fontSize": {
              "$ref": "#/$defs/Dimension"
            },
            "fontWeight": {
              "oneOf": [
                {
                  "type": "number"
                },
                {
                  "enum": [
                    "thin",
                    "extraLight",
                    "light",
                    "normal",
                    "medium",
                    "semiBold",
                    "bold",
                    "extraBold",
                    "black",
                    "regular",
                    "w100",
                    "w200",
                    "w300",
                    "w400",
                    "w500",
                    "w600",
                    "w700",
                    "w800",
                    "w900"
                  ]
                },
                {
                  "$ref": "#/$defs/Binding"
                }
              ]
            },
            "fontStyle": {
              "oneOf": [
                {
                  "enum": [
                    "normal",
                    "italic"
                  ]
                },
                {
                  "$ref": "#/$defs/Binding"
                }
              ]
            },
            "color": {
              "type": "string"
            },
            "backgroundColor": {
              "type": "string"
            },
            "letterSpacing": {
              "$ref": "#/$defs/Dimension"
            },
            "wordSpacing": {
              "$ref": "#/$defs/Dimension"
            },
            "height": {
              "$ref": "#/$defs/Dimension",
              "description": "Line-height multiplier — `height * fontSize` is the per-line vertical advance."
            },
            "decoration": {
              "oneOf": [
                {
                  "enum": [
                    "none",
                    "underline",
                    "overline",
                    "lineThrough"
                  ]
                },
                {
                  "$ref": "#/$defs/Binding"
                }
              ]
            },
            "decorationColor": {
              "type": "string"
            },
            "decorationStyle": {
              "oneOf": [
                {
                  "enum": [
                    "solid",
                    "double",
                    "dotted",
                    "dashed",
                    "wavy"
                  ]
                },
                {
                  "$ref": "#/$defs/Binding"
                }
              ]
            },
            "decorationThickness": {
              "$ref": "#/$defs/Dimension"
            },
            "fontFeatures": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "OpenType feature tags (`smcp`, `lnum`, `tnum`, `liga`, `dlig`, …)."
            },
            "shadows": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "color": {
                    "type": "string"
                  },
                  "offset": {
                    "type": "object",
                    "properties": {
                      "dx": {
                        "type": "number"
                      },
                      "dy": {
                        "type": "number"
                      },
                      "x": {
                        "type": "number"
                      },
                      "y": {
                        "type": "number"
                      }
                    },
                    "additionalProperties": false,
                    "description": "`{dx, dy}` (canonical) or `{x, y}` (legacy alias) offset."
                  },
                  "blurRadius": {
                    "$ref": "#/$defs/Dimension"
                  }
                },
                "required": [
                  "color"
                ],
                "additionalProperties": false
              }
            },
            "shader": {
              "$ref": "#/$defs/Gradient",
              "description": "Gradient/shader fill applied to the rendered text via a shader mask. When set, `color` is ignored."
            }
          },
          "additionalProperties": false
        }
      ],
      "description": "Inline text style applied per `text` widget instance. Layered on\ntop of an M3 typography role when `variant` is set, or used\nstandalone. Mirrors the theme `TextStyle` token shape (fontFamily,\nfontSize, fontWeight, lineHeight, letterSpacing, fontFeatureSettings)\nand adds the per-instance fields a content app needs: color,\ndecoration, shader (gradient fill), and shadow stack."
    },
    "ThemePreset": {
      "enum": [
        "warm",
        "cool",
        "sepia",
        "mono",
        "highContrast"
      ],
      "description": "Curated content-app theme bundle. Five named presets cover the\ncommon content-app moods. When set, the preset is applied first\n(color scheme + typography + spacing tone) and individual theme\nfields then layer overrides on top — so authors can pick a preset\nand tweak just one or two fields rather than building the whole\ntheme from scratch.\n\nPresets (color tone · typography character · spacing density):\n- `warm` — book-shelf paper tones, serif typography, cozy spacing.\n- `cool` — album / streaming ambient. Cool blues, sans-serif,\n  standard spacing.\n- `sepia` — long-form reading. Aged-paper background, increased\n  line-height, narrower content column.\n- `mono` — typography-led, neutral grays, generous line-height,\n  minimal accents.\n- `highContrast` — accessibility-first. WCAG AAA contrast ratios,\n  enlarged hit targets, bold weights."
    },
    "Typography": {
      "type": "object",
      "properties": {
        "displayLarge": {
          "$ref": "#/$defs/TextStyle"
        },
        "displayMedium": {
          "$ref": "#/$defs/TextStyle"
        },
        "displaySmall": {
          "$ref": "#/$defs/TextStyle"
        },
        "headlineLarge": {
          "$ref": "#/$defs/TextStyle"
        },
        "headlineMedium": {
          "$ref": "#/$defs/TextStyle"
        },
        "headlineSmall": {
          "$ref": "#/$defs/TextStyle"
        },
        "titleLarge": {
          "$ref": "#/$defs/TextStyle"
        },
        "titleMedium": {
          "$ref": "#/$defs/TextStyle"
        },
        "titleSmall": {
          "$ref": "#/$defs/TextStyle"
        },
        "bodyLarge": {
          "$ref": "#/$defs/TextStyle"
        },
        "bodyMedium": {
          "$ref": "#/$defs/TextStyle"
        },
        "bodySmall": {
          "$ref": "#/$defs/TextStyle"
        },
        "labelLarge": {
          "$ref": "#/$defs/TextStyle"
        },
        "labelMedium": {
          "$ref": "#/$defs/TextStyle"
        },
        "labelSmall": {
          "$ref": "#/$defs/TextStyle"
        }
      },
      "additionalProperties": false
    },
    "ZIndex": {
      "type": "object",
      "properties": {
